# ── Database ─────────────────────────────────────────────────────────────────
# Supabase: Project Settings → Database → Connection String (URI)
# Use the "Transaction" pooler URL (port 6543) for DATABASE_URL
# Use the direct connection URL (port 5432) for DIRECT_URL (used by Prisma migrations)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres"

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"
# The full public URL of your deployment (no trailing slash)
NEXTAUTH_URL="https://app.lospor.org"

# ── AI advisor (optional) ─────────────────────────────────────────────────────
# Mistral La Plateforme — EU-hosted, GDPR DPA available, free tier for small usage
# Get key at: console.mistral.ai → API Keys
MISTRAL_API_KEY=""

# ── WHO ICD-11 API ────────────────────────────────────────────────────────────
# Register at https://icd.who.int/icdapi — free, no card required
WHO_ICD_CLIENT_ID="your-who-client-id"
WHO_ICD_CLIENT_SECRET="your-who-client-secret"
